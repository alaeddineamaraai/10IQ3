VITE_SUPABASE_URL=https://xptcsydvcquxuvjqhupd.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
RESEND_API_KEY=your_resend_key_here
# Returned by `resend.webhooks.create()` (or the Resend dashboard) when you
# create the webhook pointed at /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# Subdomain with Resend's inbound MX record, used as the Reply-To address
# (reply+<outreach_id>@this-domain) so inbound replies thread back to the
# right outreach row. Must have receiving enabled in Resend.
RESEND_INBOUND_DOMAIN=reply.netset.pro
